{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash",
      "WebFetch"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "understand-anything@understand-anything": true,
    "pm-craft@agent-skills": true,
    "obsidian-tools@agent-skills": true,
    "pm-tools@agent-skills-private": true
  },
  "extraKnownMarketplaces": {
    "understand-anything": {
      "source": {
        "source": "github",
        "repo": "Lum1104/Understand-Anything"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "agent-skills": {
      "source": {
        "source": "github",
        "repo": "allan-kent/agent-skills"
      }
    },
    "agent-skills-private": {
      "source": {
        "source": "github",
        "repo": "allan-kent/agent-skills-private"
      }
    }
  },
  "tui": "fullscreen"
}
